{
  "name": "sadik-app",
  "version": "0.1.7",
  "description": "SADIK Desktop Assistant",
  "main": "electron/main.js",
  "scripts": {
    "dev": "webpack serve --mode development --port 3000",
    "dev:electron": "node electron/dev-launcher.js",
    "build": "webpack --mode production",
    "electron": "electron .",
    "convert:animation": "node scripts/convert-cpp-animation.js",
    "convert:animations": "node scripts/batch-convert-animations.js",
    "package": "npm run build && electron-builder",
    "package:dir": "npm run build && electron-builder --dir",
    "package:win": "npm run build && electron-builder --win",
    "package:mac": "npm run build && electron-builder --mac",
    "release:win": "powershell -ExecutionPolicy Bypass -File ../sadik-backend/build/build.ps1 && npm run build && electron-builder --win --publish always",
    "release": "electron-builder --publish always"
  },
  "build": {
    "appId": "com.sadik.app",
    "productName": "SADIK",
    "copyright": "© 2026 SADIK",
    "asar": true,
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../sadik-backend/dist/sadik-backend",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "build/drivers/cp210x",
        "to": "drivers/cp210x",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "requestedExecutionLevel": "asInvoker",
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "include": "build/installer.nsh"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": false,
      "icon": "build/icon.png",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "dmg": {
      "writeUpdateInfo": false
    },
    "publish": {
      "provider": "github",
      "owner": "ntrch",
      "repo": "sadik-releases"
    }
  },
  "dependencies": {
    "@ricky0123/vad-web": "^0.0.30",
    "@tiptap/extension-image": "^3.22.4",
    "@tiptap/extension-placeholder": "^3.22.4",
    "@tiptap/extension-task-item": "^3.22.4",
    "@tiptap/extension-task-list": "^3.22.4",
    "@tiptap/pm": "^3.22.4",
    "@tiptap/react": "^3.22.4",
    "@tiptap/starter-kit": "^3.22.4",
    "axios": "^1.6.7",
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.323.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "recharts": "^2.10.3"
  },
  "devDependencies": {
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@types/react-router-dom": "^5.3.3",
    "autoprefixer": "^10.4.17",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^6.10.0",
    "electron": "^28.2.2",
    "electron-builder": "^24.13.3",
    "html-webpack-plugin": "^5.6.0",
    "mini-css-extract-plugin": "^2.8.0",
    "postcss": "^8.4.35",
    "postcss-loader": "^8.1.0",
    "style-loader": "^3.3.4",
    "tailwindcss": "^3.4.1",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "webpack": "^5.90.2",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1"
  }
}
